# Скопируй в .env и заполни. Разделитель вложенности — "__".
OPENAI__API_KEY=sk-...
OPENAI__MODEL=gpt-4o-mini
# OPENAI__BASE_URL=https://api.openai.com/v1
# OPENAI__TEMPERATURE=0.0

# External development-only HAPI FHIR mock (disabled by default).
# EHR__ENABLED=true
# EHR__BASE_URL=http://localhost:8080/fhir
# EHR__TIMEOUT_SECONDS=10
# EHR__IDENTIFIER_SYSTEM=urn:medcopilot:soap-report

# Read-only mock EHR: JSON map patient_id -> plain-text patient context.
# EHR_MOCK_PATH=mock_ehr/patient_context.json
