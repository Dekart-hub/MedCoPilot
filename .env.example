# Copy to .env and fill in. Values are read by config.settings.Settings.

# Deployment environment name (dev | staging | prod).
APP_ENV=dev

# Async PostgreSQL DSN (SQLAlchemy asyncpg driver). Used by the DB engine and by
# Alembic on startup. The compose stack injects this pointing at the `postgres`
# service; override here for a local database.
DATABASE_URL=postgresql+asyncpg://medcopilot:medcopilot@postgres:5432/medcopilot

# Placeholders wired for later tasks; leave unset until then.
# VLLM_BASE_URL=http://vllm:8000/v1
# VLLM_API_KEY=
# MODEL_ID=
