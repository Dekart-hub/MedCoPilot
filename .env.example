# Copy to .env and fill in. Values are read by config.settings.Settings.

# Deployment environment name (dev | staging | prod).
APP_ENV=dev

# Async PostgreSQL DSN (SQLAlchemy asyncpg driver). Used by the DB engine and by
# Alembic on startup. The compose stack injects this pointing at the `postgres`
# service; override here for a local database.
DATABASE_URL=postgresql+asyncpg://medcopilot:medcopilot@postgres:5432/medcopilot

# MedGemma served by the `vllm` compose service over an OpenAI-compatible API.
# The compose stack sets VLLM_BASE_URL and MODEL_ID for the app; override here to
# point at a vLLM running elsewhere.
VLLM_BASE_URL=http://vllm:8000/v1
MODEL_ID=google/medgemma-4b-it
# Optional bearer token; set only if the vLLM server is launched with --api-key.
# VLLM_API_KEY=

# Hugging Face token used by the `vllm` service to pull the gated MedGemma
# checkpoint. Accept the licence at https://huggingface.co/google/medgemma-4b-it
# first, then paste a read token here.
# HF_TOKEN=
